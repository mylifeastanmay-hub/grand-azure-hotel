# ============================================================
# HOTEL MANAGEMENT SYSTEM — ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# ============================================================

# Flask secret key (change this in production!)
SECRET_KEY=change-me-to-a-random-secret-key-in-production

# SQL Server Configuration
SQL_SERVER=localhost
SQL_DATABASE=HotelManagement
SQL_USERNAME=sa
SQL_PASSWORD=YourPassword123!
SQL_DRIVER=ODBC Driver 17 for SQL Server

# Hotel Information (used in PDF invoices)
HOTEL_NAME=Grand Azure Hotel
HOTEL_ADDRESS=1 Harbor Boulevard, Suite 100
HOTEL_CITY=Miami, FL 33101
HOTEL_PHONE=+1 (305) 555-0100
HOTEL_EMAIL=reservations@grandazure.com
HOTEL_WEBSITE=www.grandazure.com

# Tax rate (0.12 = 12%)
TAX_RATE=0.12

# Flask settings
FLASK_ENV=development
FLASK_DEBUG=1
